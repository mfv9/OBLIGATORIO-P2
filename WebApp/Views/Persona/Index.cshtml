@using Dominio
@model List<Persona>
<h1>Lista de personas</h1>
<table class="table">
    <thead>
        <tr>
            <th>
                ID
            </th>
            <th>
                Nombre
            </th>
            <th>
                Cedula
            </th>
            <th>
                Email
            </th>
            <th>
                Telefono
            </th>
            <th>
                Rol
            </th>

            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @item.Id
                </td>
                <td>
                    @item.Nombre
                </td>
                <td>
                    @item.Cedula
                </td>
                <td>
                    @item.Email
                </td>
                <td>
                    @item.Telefono
                </td>
                <td>
                    @item.Rol
                </td>
                <td>
                    @Html.ActionLink("Ver cuentas", "Details", "Cuenta", new { id = item.Id })
                    @Html.ActionLink("Crear cuenta", "Create", "Cuenta", new { id = item.Id })

                </td>
            </tr>
        }
    </tbody>
</table>