@{
    int? lid = Context.Session.GetInt32("LogueadoId");
    string lrol = Context.Session.GetString("LogueadoRol");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - webapp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/webapp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WebApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @if (lid == null)
                        {
                            @* Acá van los botones que ve el deslogueado *@
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Iniciar Sesion</a>
                            </li>

                        }
                        else
                        {
                            @* Acá van los botones que ven los dos roles *@

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Menu" asp-route-id="@lid">Menu</a>
                            </li>                       
                            <a class="nav-link text-dark" asp-area="" asp-controller="Persona" asp-action="Details" asp-route-id="@lid">Ver perfil</a>
                            if (lrol == "Administrador")
                            {
                                <a class="nav-link text-dark" asp-area="" asp-controller="Persona" asp-action="Index">Ver clientes</a>
                                <a class="nav-link text-dark" asp-area="" asp-controller="Incidente" asp-action="Index">Ver incidentes</a>
                            }
                            else if (lrol == "Operador")
                            {
                                @* acá van los botones que ve solo el cliente *@

                                <a class="nav-link text-dark" asp-area="" asp-controller="Activo" asp-action="PersonaActivos" asp-route-id="@lid">Ver activo</a>
                            }

                            <li class="nav-item logout-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>

                        }







                      
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - webapp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
