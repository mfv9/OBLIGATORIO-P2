@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Menú Principal";
    var persona = ViewBag.Persona;

    int? lid = Context.Session.GetInt32("LogueadoId");
    string lrol = Context.Session.GetString("LogueadoRol");
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg overflow-hidden animate-fade-in">

                <div class="card-header bg-gradient-primary text-white text-center py-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-person-circle mb-2" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                    </svg>
                    <h1 class="display-6 m-0 fw-bold">¡Bienvenido de nuevo!</h1>
                </div>

                <div class="card-body p-5 text-center">
                    @if (persona != null)
                    {
                        <h2 class="text-secondary mb-3">Hola, <span class="text-primary fw-semibold">@persona.Nombre</span> 👋</h2>
                        <p class="text-muted lead">Nos alegra tenerte de vuelta en el sistema. ¿Qué te gustaría hacer hoy?</p>
                    }
                    else
                    {
                        <h2 class="text-secondary mb-3">Hola, <span class="text-primary fw-semibold">Usuario</span> 👋</h2>
                        <p class="text-muted lead">Acceso concedido al menú principal.</p>
                    }

                    <hr class="my-4 text-muted">

                    <div class="row g-3 mt-2 justify-content-center">

                        <div class="col-6 col-sm-4">
                            <a asp-controller="Persona" asp-action="Details" asp-route-id="@lid" class="btn btn-outline-primary w-100 py-3 shadow-sm custom-card">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="d-block mx-auto mb-2" viewBox="0 0 16 16">
                                    <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z" />
                                    <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.893 1.64.902 3.433 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.292-.16c.764-.415 1.6.42 1.185 1.185l-.16.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.292c.415.764-.42 1.6-1.185 1.185l-.292-.16a1.873 1.873 0 0 0-2.693 1.115l-.094.319c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.185-1.185l.16-.292a1.873 1.873 0 0 0-1.115-2.692l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094a1.873 1.873 0 0 0 1.115-2.692l-.16-.292c-.415-.764.42-1.6 1.185-1.185l.292.16A1.873 1.873 0 0 0 7.163 1.95l.094-.319z" />
                                </svg>
                                Mi Perfil
                            </a>
                        </div>

                        @if (lrol == "Administrador")
                        {
                            <div class="col-6 col-sm-4">
                                <a asp-controller="Persona" asp-action="Index" class="btn btn-outline-success w-100 py-3 shadow-sm custom-card">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="d-block mx-auto mb-2" viewBox="0 0 16 16">
                                        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816ZM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724C2.307 10.635 3.267 10 5 10c.048 0 .096.001.144.003l-.223.242ZM4.5 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm0-4a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Z" />
                                    </svg>
                                    Ver Clientes
                                </a>
                            </div>
                        }
                        else if (lrol == "Operador")
                        {
                            <div class="col-6 col-sm-4">
                                <a asp-controller="Activo" asp-action="PersonaActivos" asp-route-id="@lid" class="btn btn-outline-success w-100 py-3 shadow-sm custom-card">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="d-block mx-auto mb-2" viewBox="0 0 16 16">
                                        <path d="M8 1a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V1Zm1 .5v13h6v-13H9Zm2 1.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1Zm0 3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1ZM3.5 1a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-3ZM2 1.5A1.5 1.5 0 0 1 3.5 0h3A1.5 1.5 0 0 1 8 1.5v9A1.5 1.5 0 0 1 6.75 12H5.5v1h1a.5.5 0 0 1 0 1h-3a.5.5 0 0 1 0-1h1v-1H1.25A1.5 1.5 0 0 1 0 10.5v-9A1.5 1.5 0 0 1 1.5 0H2v1.5ZM1.5 1a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5H2v-10h-.5Z" />
                                    </svg>
                                    Ver Activos
                                </a>
                            </div>
                        }

                        <div class="col-6 col-sm-4">
                            <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger w-100 py-3 shadow-sm custom-card">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="d-block mx-auto mb-2" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M6 12.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v2a.5.5 0 0 1-1 0v-2A1.5 1.5 0 0 1 6.5 1h8A1.5 1.5 0 0 1 16 2.5v9a1.5 1.5 0 0 1-1 1.5h-8A1.5 1.5 0 0 1 5 11.5v-2a.5.5 0 0 1 1 0v2z" />
                                    <path fill-rule="evenodd" d="M.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L1.707 7.5H10.5a.5.5 0 0 1 0 1H1.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3z" />
                                </svg>
                                Cerrar Sesión
                            </a>
                        </div>

                    </div>
                </div>

                <div class="card-footer bg-light text-center py-3 text-muted small">
                    Sesión activa ID: @lid | Rol: @(lrol ?? "No asignado")
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .custom-card {
        transition: all 0.3s ease;
        border-radius: 12px;
    }

        .custom-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
        }

    .animate-fade-in {
        animation: fadeIn 0.6s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>